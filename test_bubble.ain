fn swap(arr, i, j) {
    let temp = arr[i];
    arr[i] = arr[j];
    arr[j] = temp;
}

fn bubble_sort(arr, n) {
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < n - i - 1) {
            if (arr[j] > arr[j + 1]) {
                swap(arr, j, j + 1);
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

let numbers = [64, 34, 25, 12, 22, 11, 90];
bubble_sort(numbers, 7);

let k = 0;
while (k < 7) {
    print(numbers[k]);
    k = k + 1;
}
